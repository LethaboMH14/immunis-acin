# IMMUNIS ACIN — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to git.

# === AIsa.one (Primary AI API — Claude, GPT, DeepSeek) ===
aisa_api_key=your_aisa_api_key_here
aisa_base_url=https://api.aisa.one/v1

# === AMD Developer Cloud ===
amd_api_key=your_amd_key_here
amd_endpoint=your_amd_endpoint_here

# === HuggingFace ===
hf_token=your_hf_token_here
hf_organization=amd-developer-hackathon

# === Model Inference ===
vllm_endpoint=http://localhost:8080
sentinel_model_id=immunis/immunis-sentinel-7b-qlora
adversary_model_id=immunis/immunis-adversary-8b-rlhf
vision_model_id=immunis/immunis-vision-7b-qlora

# === Fallback AI APIs ===
openrouter_api_key=your_openrouter_key_here
groq_api_key=your_groq_key_here

# === Local Models (Ollama) ===
ollama_base_url=http://localhost:11434
ollama_model=qwen2.5-coder:7b

# === Database ===
database_url=sqlite:///./immunis.db
vector_store_path=./data/faiss_index

# === Security ===
jwt_secret=CHANGE_ME_IN_PRODUCTION
node_private_key=generate_on_first_run
lockout_hardware_key_id=

# === Mesh Network ===
immunis_node_id=node-primary-001
immunis_mesh_port=8765
immunis_mesh_peers=

# === Application ===
port=8000
frontend_url=http://localhost:3000
debug=true
log_level=INFO

# === Feature Flags ===
enable_battleground=true
enable_vision=true
enable_scanner=true
enable_deception=true
enable_stix_taxii=true
enable_biometrics=false
enable_post_quantum=true

# === Thresholds ===
battleground_max_iterations=20
battleground_promotion_threshold=0.85
surprise_known_threshold=3.0
surprise_novel_threshold=8.0

# === PID Controller ===
pid_kp=0.5
pid_ki=0.1
pid_kd=0.3
immunity_target=85.0
